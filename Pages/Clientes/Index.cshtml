@page
@model LojaApp.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<h1>Gestão de Clientes</h1>

<p>
    <a href="/Clientes/Create">Adicionar Novo Cliente</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Cliente)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nome)</td>
                <td>@Html.DisplayFor(modelItem => item.Telefone)</td>
                <td>
                    <a href="/Clientes/Edit/@item.ClienteID">Editar</a> |
                    <a href="/Clientes/Delete/@item.ClienteID">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>