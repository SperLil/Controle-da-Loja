@page "{id:int}"
@model LojaApp.Pages.Produtos.RegistrarVendaModel
@{
    ViewData["Title"] = "Registar Venda";
}

<h1>Registar Venda</h1>
<hr />

<div>
    <h4>Produto</h4>
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Produto.Nome)</dd>

        <dt class="col-sm-2">Preço (unid.)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Produto.Preco)</dd>

        <dt class="col-sm-2">Em Stock</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Produto.Quantidade)</dd>
    </dl>
</div>

<hr />

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label>Quantidade a Vender:</label>
                <input asp-for="QuantidadeVendida" class="form-control" type="number" min="1" max="@Model.Produto.Quantidade" />
            </div>

            <div class="form-group mt-3">
                <label>Vender para o Cliente:</label>
                <select asp-for="ClienteSelecionadoID" asp-items="@Model.ListaClientes" class="form-control"></select>
                <small>Não encontrou o cliente? <a href="/Clientes/Create" target="_blank">Adicione um novo cliente aqui</a>.</small>
            </div>

            <div class="form-group mt-3">
                <label>Status do Pagamento:</label>
                <select asp-for="StatusPagamento" class="form-control">
                    <option value="Pago">Pago</option>
                    <option value="Fiado">Fiado (Pendente)</option>
                </select>
            </div>

            <div class="form-group" style="margin-top: 20px;">
                <input type="submit" value="Registar Venda" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a href="/Produtos/Index">Cancelar (Voltar para o Stock)</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}